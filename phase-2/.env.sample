# Phase 2 – Environment Variables
# Copy this file to .env and fill in the values before starting the server.
# Usage: cp .env.sample .env

# ─── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite database created by phase-1.
# Default: ../phase-1/phase1.db (relative to this folder's parent)
DATABASE_FILE=../phase-1/phase1.db

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4002

# ─── Groq LLM ────────────────────────────────────────────────────────────────
# Required for theme generation, review assignment, and pulse generation.
# Get your key at https://console.groq.com/
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# Groq model to use. Recommended: llama-3.1-70b-versatile
GROQ_MODEL=llama-3.1-70b-versatile

# ─── SMTP (Email) ────────────────────────────────────────────────────────────
# Required for /api/pulses/:id/send-email and the scheduler to actually send emails.
# Gmail example: use App Password (not your login password).
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-16-char-app-password
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.YOUR_SENDGRID_API_KEY

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# From address shown in the recipient's inbox.
# Defaults to SMTP_USER if not set.
SMTP_FROM=Groww Review Insights <your-email@gmail.com>
